<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ========== 第一层：顶部植物收集进度区 ========== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- 底层：卡片白色背景 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_card_warm" />

            <!-- 中层：侧边树枝，从头像左侧延伸到右边界，可被内容遮挡 -->
            <com.mrlaughing.moyuan.render.SideBranchTreeView
                android:id="@+id/view_side_branch"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- 顶层：卡片内容（在树枝之上） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <!-- 用户信息行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/image_avatar"
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:background="@drawable/bg_avatar_circle"
                    android:contentDescription="@string/desc_profile_plant"
                    android:padding="5dp"
                    android:scaleType="fitCenter" />

                <!-- 昵称 + 签名 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <!-- "墨园"品牌名 — 霞鹜文楷(文学温度层) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="墨园"
                        android:textColor="@color/ink_dark"
                        android:textSize="20sp"
                        android:fontFamily="@font/lxgw_wenkai"
                        android:textStyle="bold" />

                    <!-- 诗词签名 — 霞鹜文楷(文学温度层) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_tagline"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="@font/lxgw_wenkai"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginVertical="12dp" />

            <!-- 植物收集进度数字行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 总数 — 前数字粗体 -->
                <TextView
                    android:id="@+id/text_total_plants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink_dark"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif"
                    tools:text="5 / 50 植物" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- 查看图鉴 — 右对齐 -->
                <LinearLayout
                    android:id="@+id/layout_view_catalog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_view_catalog"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="@font/lxgw_wenkai" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" →"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

            </LinearLayout>

            <!-- 墨痕进度条 -->
            <ProgressBar
                android:id="@+id/progress_plants"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="8dp"
                android:progressDrawable="@drawable/bg_plant_progress"
                android:progress="0"
                tools:max="50"
                tools:progress="5" />

            </LinearLayout>

        </FrameLayout>

        <!-- ========== 第二层：成就区域 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- 成就标题行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- "成就"标题 — 京华老宋(结构阅读层) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_achievements"
                    android:textColor="@color/ink_dark"
                    android:textSize="18sp"
                    android:fontFamily="@font/jinghua_laosong"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" │ "
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

                <!-- 成就计数 — 思源黑体(功能数据层) -->
                <TextView
                    android:id="@+id/text_achievement_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    tools:text="3枚" />

            </LinearLayout>

            <!-- 分类Tab — 思源黑体(功能数据层) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cat_all"
                    android:textColor="@color/ink_dark"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:background="@color/border"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/tab_reading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cat_reading"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:paddingBottom="4dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:background="@color/border"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/tab_growth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cat_growth"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:paddingBottom="4dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:background="@color/border"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/tab_milestone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cat_milestone"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:paddingBottom="4dp" />

            </LinearLayout>

            <!-- 指示条 -->
            <View
                android:id="@+id/indicator"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:background="@color/ink_dark"
                android:layout_marginBottom="8dp" />

            <!-- 成就列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_achievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_achievement"
                tools:itemCount="3" />

        </LinearLayout>

        <!-- ========== 第三层：底部设置区 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_warm"
            android:padding="16dp">

            <!-- 设置标题 — 京华老宋(结构阅读层) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_settings"
                    android:textColor="@color/ink_dark"
                    android:textSize="18sp"
                    android:fontFamily="@font/jinghua_laosong"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" │ "
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <!-- 微信读书 — 京华老宋(结构阅读层) -->
            <LinearLayout
                android:id="@+id/card_weread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_weread_auth"
                    android:textColor="@color/ink_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/jinghua_laosong" />

                <!-- 状态 — 思源黑体(功能数据层) -->
                <TextView
                    android:id="@+id/text_weread_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    tools:text="已授权" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" →"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border" />

            <!-- 同步时间 — 京华老宋(结构阅读层) -->
            <LinearLayout
                android:id="@+id/layout_sync_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_sync_time"
                    android:textColor="@color/ink_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/jinghua_laosong" />

                <!-- 时间值 — 思源黑体(功能数据层) -->
                <TextView
                    android:id="@+id/text_sync_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    tools:text="08:00" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" →"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border" />

            <!-- 立即同步 — 京华老宋(结构阅读层) -->
            <LinearLayout
                android:id="@+id/layout_sync_now"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_sync_now"
                    android:textColor="@color/ink_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/jinghua_laosong" />

                <!-- 上次同步 — 思源黑体(功能数据层) -->
                <TextView
                    android:id="@+id/text_last_sync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    tools:text="上次: 2024-01-01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" →"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border" />

            <!-- 关于墨园 — 京华老宋(结构阅读层) -->
            <LinearLayout
                android:id="@+id/layout_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_about_moyuan"
                    android:textColor="@color/ink_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/jinghua_laosong" />

                <!-- 版本号 — 思源黑体(功能数据层) -->
                <TextView
                    android:id="@+id/text_about_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    tools:text="v1.0.0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" →"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
