<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xuan_paper"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 页面标题：我的 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/nav_profile"
            android:textColor="@color/pure_black"
            android:textSize="24sp"
            android:fontFamily="@font/lxgw_wenkai"
            android:textStyle="bold" />

        <!-- 1. 花园概况卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_garden_overview"
                android:textColor="@color/pure_black"
                android:textSize="16sp"
                android:fontFamily="@font/lxgw_wenkai"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_plant_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/deep_gray"
                android:textSize="14sp"
                android:fontFamily="@font/lxgw_wenkai" />

            <TextView
                android:id="@+id/text_unlock_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/medium_gray"
                android:textSize="12sp"
                android:fontFamily="@font/lxgw_wenkai" />

        </LinearLayout>

        <!-- 2. 微信读书卡片 -->
        <LinearLayout
            android:id="@+id/card_weread"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_weread_auth"
                android:textColor="@color/pure_black"
                android:textSize="16sp"
                android:fontFamily="@font/lxgw_wenkai"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_weread_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/deep_gray"
                    android:textSize="14sp"
                    android:fontFamily="@font/lxgw_wenkai" />

                <TextView
                    android:id="@+id/text_last_sync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/medium_gray"
                    android:textSize="12sp"
                    android:fontFamily="@font/lxgw_wenkai" />

            </LinearLayout>

        </LinearLayout>

        <!-- 3. 同步设置卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_sync_settings"
                android:textColor="@color/pure_black"
                android:textSize="16sp"
                android:fontFamily="@font/lxgw_wenkai"
                android:textStyle="bold" />

            <!-- 同步时间 -->
            <LinearLayout
                android:id="@+id/layout_sync_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_sync_time"
                    android:textColor="@color/deep_gray"
                    android:textSize="14sp"
                    android:fontFamily="@font/lxgw_wenkai" />

                <TextView
                    android:id="@+id/text_sync_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/medium_gray"
                    android:textSize="14sp"
                    android:fontFamily="@font/lxgw_wenkai" />

            </LinearLayout>

        </LinearLayout>

        <!-- 4. 刷新模式卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_refresh_mode"
                android:textColor="@color/pure_black"
                android:textSize="16sp"
                android:fontFamily="@font/lxgw_wenkai"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layout_refresh_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_refresh_mode"
                    android:textColor="@color/deep_gray"
                    android:textSize="14sp"
                    android:fontFamily="@font/lxgw_wenkai" />

                <TextView
                    android:id="@+id/text_refresh_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/medium_gray"
                    android:textSize="14sp"
                    android:fontFamily="@font/lxgw_wenkai" />

            </LinearLayout>

        </LinearLayout>

        <!-- 5. 关于墨园卡片 -->
        <LinearLayout
            android:id="@+id/layout_about"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_about_moyuan"
                android:textColor="@color/pure_black"
                android:textSize="16sp"
                android:fontFamily="@font/lxgw_wenkai"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_about_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/medium_gray"
                android:textSize="12sp"
                android:fontFamily="@font/lxgw_wenkai" />

        </LinearLayout>

        <!-- 隐藏的旧视图 -->
        <TextView
            android:id="@+id/text_garden_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
        <TextView
            android:id="@+id/text_sync_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
        <View
            android:id="@+id/layout_sync_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
