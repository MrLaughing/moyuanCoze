<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xuan_paper">

    <!-- 左上角：竖排书法「墨园」 -->
    <TextView
        android:id="@+id/text_moyuan_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="墨园"
        android:textColor="@color/pure_black"
        android:textSize="28sp"
        android:fontFamily="@font/lxgw_wenkai"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 右上角：天气·季节·日期 -->
    <LinearLayout
        android:id="@+id/top_info_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_weather_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/deep_gray"
            android:textSize="14sp"
            android:fontFamily="@font/lxgw_wenkai" />

    </LinearLayout>

    <!-- 花园渲染画面 -->
    <FrameLayout
        android:id="@+id/garden_frame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/text_moyuan_title"
        app:layout_constraintBottom_toTopOf="@id/info_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.mrlaughing.moyuan.ui.garden.GardenRendererView
            android:id="@+id/garden_renderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- 右下角：灌溉进度 -->
    <TextView
        android:id="@+id/text_irrigation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:textColor="@color/medium_gray"
        android:textSize="12sp"
        android:fontFamily="@font/lxgw_wenkai"
        app:layout_constraintBottom_toTopOf="@id/info_bar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 信息条：今日阅读 · 连续天数 · 加成 -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="0dp"
        android:layout_height="@dimen/info_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_info_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/pure_black"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai" />

    </LinearLayout>

    <!-- 隐藏的旧视图（保留ID供代码引用） -->
    <TextView
        android:id="@+id/text_season"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />
    <TextView
        android:id="@+id/text_weather"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />
    <TextView
        android:id="@+id/text_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />
    <TextView
        android:id="@+id/text_today_read"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />
    <TextView
        android:id="@+id/text_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />
    <TextView
        android:id="@+id/text_bonus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
