<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xuan_paper">

    <!-- 顶栏：季节 + 天气 + 日期 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_season"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/pure_black"
            android:textSize="16sp"
            android:fontFamily="@font/lxgw_wenkai" />

        <TextView
            android:id="@+id/text_weather"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/deep_gray"
            android:textSize="14sp"
            android:fontFamily="@font/lxgw_wenkai" />

        <TextView
            android:id="@+id/text_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textColor="@color/medium_gray"
            android:textSize="14sp"
            android:fontFamily="@font/lxgw_wenkai" />

    </LinearLayout>

    <!-- 花园渲染画面 -->
    <FrameLayout
        android:id="@+id/garden_frame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/info_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.mrlaughing.moyuan.ui.garden.GardenRendererView
            android:id="@+id/garden_renderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- 信息条：今日阅读 + 连续天数 + 加成 -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="0dp"
        android:layout_height="@dimen/info_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_today_read"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/pure_black"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai" />

        <TextView
            android:id="@+id/text_streak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/deep_gray"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai" />

        <TextView
            android:id="@+id/text_bonus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textColor="@color/medium_gray"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
