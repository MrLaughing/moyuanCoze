<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper_bg">

    <!-- 顶部顶栏 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 左上角：竖排书法「墨园」 -->
        <TextView
            android:id="@+id/text_moyuan_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="墨园"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="@font/lxgw_wenkai" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 右侧：季节/天气/日期 Pill 标签 -->
        <TextView
            android:id="@+id/tag_season"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="春·萌芽"
            android:textColor="@color/text_on_dark"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai"
            android:background="@drawable/bg_pill_dark"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/tag_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="晴"
            android:textColor="@color/text_on_dark"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai"
            android:background="@drawable/bg_pill_dark"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/tag_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="三月十五"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai"
            android:background="@drawable/bg_pill_light"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/border"
        android:alpha="0.4"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 花园渲染画面（Canvas） -->
    <FrameLayout
        android:id="@+id/garden_frame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/wither_alert_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.mrlaughing.moyuan.ui.garden.GardenRendererView
            android:id="@+id/garden_renderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- 枯萎预警卡片（无枯萎时隐藏） -->
    <LinearLayout
        android:id="@+id/wither_alert_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_wither_alert"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/info_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_wither_alert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8B7355"
            android:textSize="11sp"
            android:fontFamily="@font/lxgw_wenkai"
            android:text="⚠ 1株植物开始枯萎，请浇灌" />

    </LinearLayout>

    <!-- 底部信息卡片：三列布局 -->
    <LinearLayout
        android:id="@+id/info_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        app:layout_constraintBottom_toTopOf="@id/path_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 三列数据 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- 今日阅读 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日阅读"
                    style="@style/GardenStatLabel" />

                <TextView
                    android:id="@+id/text_today_read"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    style="@style/GardenStatValue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分钟"
                    style="@style/GardenStatUnit" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="@color/border"
                android:alpha="0.4" />

            <!-- 连续天数 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="连续天数"
                    style="@style/GardenStatLabel" />

                <TextView
                    android:id="@+id/text_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    style="@style/GardenStatValue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="天"
                    style="@style/GardenStatUnit" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="@color/border"
                android:alpha="0.4" />

            <!-- 加成倍率 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="加成倍率"
                    style="@style/GardenStatLabel" />

                <TextView
                    android:id="@+id/text_bonus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="×1.0"
                    style="@style/GardenStatValue" />

                <TextView
                    android:id="@+id/text_bonus_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="春·晴"
                    style="@style/GardenStatUnit" />

            </LinearLayout>

        </LinearLayout>

        <!-- 植物状态汇总 -->
        <TextView
            android:id="@+id/text_plant_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_sm"
            android:background="@drawable/bg_top_border"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="@font/lxgw_wenkai"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 路径加成信息卡片 -->
    <LinearLayout
        android:id="@+id/path_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_path_card"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        app:layout_constraintBottom_toTopOf="@id/water_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前加成路径"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="@font/lxgw_wenkai" />

        <TextView
            android:id="@+id/text_path_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="积墨 · 秉烛 ×1.2"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="@font/lxgw_wenkai" />

    </LinearLayout>

    <!-- 浇灌按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/water_button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="浇灌 · 今日阅读 0 分钟"
        android:textColor="@color/text_on_dark"
        android:textSize="14sp"
        android:fontFamily="@font/lxgw_wenkai"
        android:textAllCaps="false"
        app:backgroundTint="@color/ink_dark"
        app:cornerRadius="8dp"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 灌溉进度文字（隐藏，供代码引用） -->
    <TextView
        android:id="@+id/text_irrigation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- 右上角旧天气日期（隐藏，供代码引用） -->
    <TextView
        android:id="@+id/text_weather_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- 信息条旧文本（隐藏，供代码引用） -->
    <TextView
        android:id="@+id/text_info_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
