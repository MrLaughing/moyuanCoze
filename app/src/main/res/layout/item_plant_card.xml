<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/catalog_card_width"
    android:layout_height="@dimen/catalog_card_height"
    android:background="@color/white"
    android:padding="8dp">

    <!-- 植物图片 -->
    <ImageView
        android:id="@+id/image_plant"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:contentDescription="@string/desc_plant_image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/text_plant_name" />

    <!-- 植物名字 -->
    <TextView
        android:id="@+id/text_plant_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:fontFamily="@font/lxgw_wenkai"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/image_plant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/text_plant_level" />

    <!-- 等级 -->
    <TextView
        android:id="@+id/text_plant_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/ink_medium"
        android:textSize="10sp"
        android:fontFamily="@font/lxgw_wenkai"
        app:layout_constraintTop_toBottomOf="@id/text_plant_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/text_plant_stars"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 稀有度星标 -->
    <TextView
        android:id="@+id/text_plant_stars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        app:layout_constraintTop_toBottomOf="@id/text_plant_name"
        app:layout_constraintStart_toEndOf="@id/text_plant_level"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
