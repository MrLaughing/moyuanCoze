<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_container"
    android:layout_width="@dimen/catalog_card_width"
    android:layout_height="@dimen/catalog_card_height"
    android:background="@color/white"
    android:padding="0dp">

    <!-- 图片区域背景（渐变层） -->
    <View
        android:id="@+id/view_image_gradient"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_image_gradient_unlocked"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/text_plant_name" />

    <!-- 植物图片 -->
    <ImageView
        android:id="@+id/image_plant"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:padding="8dp"
        android:contentDescription="@string/desc_plant_image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/divider" />

    <!-- 分割线 -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/border"
        app:layout_constraintTop_toBottomOf="@id/image_plant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/text_plant_name" />

    <!-- 植物名字 - 粗体 -->
    <TextView
        android:id="@+id/text_plant_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="@font/lxgw_wenkai"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/text_plant_level" />

    <!-- 等级 - 细体 -->
    <TextView
        android:id="@+id/text_plant_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="@font/lxgw_wenkai"
        app:layout_constraintTop_toBottomOf="@id/text_plant_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/text_plant_stars"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 稀有度星标 - 细体 -->
    <TextView
        android:id="@+id/text_plant_stars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/ink_light"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/text_plant_name"
        app:layout_constraintStart_toEndOf="@id/text_plant_level"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
