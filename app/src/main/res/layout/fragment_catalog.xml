<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paper_bg">

    <!-- 标题行：图鉴 + 已解锁数量 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        android:background="@color/white">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_catalog"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="@font/lxgw_wenkai"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_unlocked_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/lxgw_wenkai" />

    </LinearLayout>

    <!-- 路径筛选：横向滚动标签 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/white"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_path"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/label_path_all"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/lxgw_wenkai"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="18dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_jimo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/label_path_jimo"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/lxgw_wenkai"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="18dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_bingzhu"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/label_path_bingzhu"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/lxgw_wenkai"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="18dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_suihan"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/label_path_suihan"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/lxgw_wenkai"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="18dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_xunfang"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/label_path_xunfang"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/lxgw_wenkai"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="18dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_hidden"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/label_path_hidden"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/lxgw_wenkai"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="18dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- 植物卡片网格 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_catalog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_sm"
        android:clipToPadding="false" />

</LinearLayout>
