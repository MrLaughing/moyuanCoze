<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paper_bg">

    <!-- 标题行：图鉴 + 已解锁数量 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        android:background="@color/paper_bg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_catalog"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="@font/jinghua_laosong"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_unlocked_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_sm">

        <TextView
            android:id="@+id/filter_all"
            style="@style/PillTag.Dark"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/label_cat_all" />

        <TextView
            android:id="@+id/filter_discovered"
            style="@style/PillTag.Light"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/catalog_filter_discovered" />

        <TextView
            android:id="@+id/filter_undiscovered"
            style="@style/PillTag.Light"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/catalog_filter_undiscovered" />
    </LinearLayout>

    <!-- 植物卡片网格 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_catalog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_sm"
        android:clipToPadding="false" />

</LinearLayout>
